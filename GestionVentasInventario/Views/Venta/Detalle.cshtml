@model GestionVentasInventario.Models.Venta
@{
    ViewData["Title"] = "Detalle de Venta";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Venta #@Model.ID</h2>
        <a asp-action="Index" class="btn btn-secondary">← Volver</a>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-dark text-white">Información de la Venta</div>
                <div class="card-body">
                    <p><strong>Fecha:</strong> @Model.FechaVenta.ToString("dd/MM/yyyy HH:mm")</p>
                    <p><strong>Cliente:</strong> @Model.Cliente?.NombreCompleto</p>
                    <p><strong>DNI:</strong> @Model.Cliente?.DNI</p>
                    <p><strong>Vendedor:</strong> @Model.Usuario?.NombreCompleto</p>
                    <p><strong>Método de Pago:</strong> @Model.MetodoPago</p>
                    <p>
                        <strong>Estado:</strong>
                        <span class="badge bg-success">@Model.Estado</span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <table class="table table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Producto</th>
                <th>Precio Unit.</th>
                <th>Cantidad</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var detalle in Model.Detalles)
            {
                <tr>
                    <td>@detalle.Producto?.Nombre</td>
                    <td>S/ @detalle.PrecioUnitario.ToString("0.00")</td>
                    <td>@detalle.Cantidad</td>
                    <td>S/ @detalle.Subtotal.ToString("0.00")</td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr class="table-success">
                <td colspan="3" class="text-end fw-bold">TOTAL:</td>
                <td class="fw-bold">S/ @Model.Total.ToString("0.00")</td>
            </tr>
        </tfoot>
    </table>
</div>