@model IEnumerable<GestionVentasInventario.Models.Venta>
@{
    ViewData["Title"] = "Ventas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Ventas</h2>
        <a asp-action="Crear" class="btn btn-primary">+ Nueva Venta</a>
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success">@TempData["Exito"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Fecha</th>
                <th>Cliente</th>
                <th>Vendedor</th>
                <th>Método Pago</th>
                <th>Total</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ID</td>
                    <td>@item.FechaVenta.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@item.Cliente?.NombreCompleto</td>
                    <td>@item.Usuario?.NombreCompleto</td>
                    <td>@item.MetodoPago</td>
                    <td>S/ @item.Total.ToString("0.00")</td>
                    <td><span class="badge bg-success">@item.Estado</span></td>
                    <td>
                        <a asp-action="Detalle" asp-route-id="@item.ID"
                           class="btn btn-sm btn-info text-white">Ver Detalle</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>